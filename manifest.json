{
  "manifest_version": 3,
  "name": "FileDrop",
  "description": "Share files directly with users or post files to an organization board.",
  "version": "0.1.0",
  "action": {
    "default_title": "FileDrop",
    "default_popup": "index.html"
  },
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
